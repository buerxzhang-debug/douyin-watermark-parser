/* pages/index/index.wxss */

/* ===== 输入区域 ===== */
.input-section {
  padding: 24rpx 32rpx;
}

.input-card {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx 20rpx;
  box-shadow: var(--shadow-sm);
}

.input-top {
  margin-bottom: 16rpx;
}

.input-badge {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  letter-spacing: 2rpx;
}

.url-input {
  width: 100%;
  min-height: 120rpx;
  max-height: 200rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.placeholder {
  color: var(--text-hint);
  font-size: 28rpx;
}

.input-bottom {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.chip-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg);
  transition: all 0.15s;
}

.chip-btn:active {
  background: #E8E5F0;
  transform: scale(0.96);
}

.chip-paste {
  color: var(--primary, #6C5CE7);
  background: rgba(108, 92, 231, 0.1);
  font-weight: 600;
}

.chip-paste:active {
  background: rgba(108, 92, 231, 0.2);
}

.chip-icon {
  font-size: 22rpx;
}

.char-count {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* ===== 解析按钮 ===== */
.parse-btn {
  margin-top: 24rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(108, 92, 231, 0.3);
  transition: all 0.2s;
}

.parse-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.3);
}

.parse-btn.loading {
  background: linear-gradient(135deg, #B0A8D8, #9E95C7);
  box-shadow: none;
  letter-spacing: 2rpx;
}

.loading-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.25);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 错误提示 ===== */
.error-toast {
  margin: 16rpx 32rpx 0;
  padding: 20rpx 24rpx;
  background: #FFF0F0;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.error-dot {
  font-size: 16rpx;
  color: #FF5252;
}

.error-text {
  font-size: 26rpx;
  color: #D32F2F;
  line-height: 1.4;
}

/* ===== 结果区域 ===== */
.result-section {
  padding: 0 32rpx 24rpx;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.type-pill {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.pill-video {
  background: rgba(64, 158, 255, 0.1);
  color: #409EFF;
}

.pill-note {
  background: rgba(255, 153, 0, 0.1);
  color: #FF9900;
}

.result-author {
  font-size: 24rpx;
  color: var(--text-hint);
}

.result-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 20rpx;
}

/* ===== 媒体展示 ===== */
.media-wrap {
  background: var(--card);
  border-radius: var(--radius-md);
  padding: 16rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.result-video {
  width: 100%;
  border-radius: var(--radius-sm);
}

.image-grid-3 {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.grid-thumb {
  width: calc((100% - 16rpx) / 3);
  aspect-ratio: 1 / 1;
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.thumb-image {
  width: 100%;
  height: 100%;
  display: block;
}

.thumb-index {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  padding: 0 8rpx;
}

/* ===== 操作栏 ===== */
.action-bar {
  margin-top: 20rpx;
}

.action-bar-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-main-btn {
  height: 88rpx;
  border-radius: var(--radius-full);
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 24rpx rgba(108, 92, 231, 0.25);
}

.action-main-btn:active {
  transform: scale(0.98);
}

.save-hint {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-hint);
  letter-spacing: 1rpx;
}

.save-hint-top {
  margin-top: 0;
  margin-bottom: 16rpx;
  padding: 12rpx 20rpx;
  background: rgba(108, 92, 231, 0.08);
  color: var(--primary, #6C5CE7);
  border-radius: var(--radius-md, 12rpx);
  font-size: 24rpx;
  letter-spacing: 1rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-sub-btn {
  flex: 1;
  height: 76rpx;
  border-radius: var(--radius-full);
  background: var(--card);
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 500;
}

.action-sub-btn:active {
  background: var(--bg);
  transform: scale(0.98);
}

/* ===== 封面区域 ===== */
.cover-section {
  margin-top: 20rpx;
}

.section-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.label-hint {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--text-hint);
  margin-left: 8rpx;
}

.cover-wrap {
  background: var(--card);
  border-radius: var(--radius-md);
  padding: 12rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.cover-image {
  width: 100%;
  border-radius: var(--radius-sm);
  display: block;
}

/* ===== 文案区域 ===== */
.desc-section {
  margin-top: 20rpx;
}

.desc-card {
  background: var(--card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.desc-full-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
  word-break: break-all;
}

/* ===== 引导区域 ===== */
.guide-section {
  margin: 16rpx 32rpx 0;
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.guide-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 28rpx;
}

.guide-steps {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-step {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  min-width: 44rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-top: 2rpx;
}

.step-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.step-main {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.step-sub {
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 1.5;
}

.guide-note {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
  text-align: center;
}
