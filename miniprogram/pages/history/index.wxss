/* pages/history/index.wxss */

/* 返回按钮 */
.nav-back {
  position: absolute;
  left: 16rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid var(--text-primary);
  border-bottom: 4rpx solid var(--text-primary);
  transform: rotate(45deg);
}

/* ===== 工具栏 ===== */
.toolbar {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  gap: 16rpx;
}

.toolbar-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.toolbar-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  color: var(--text-secondary);
  background: var(--card);
  border: 1rpx solid var(--border);
}

.toolbar-btn.danger {
  color: #e74c3c;
  border-color: #e74c3c;
  background: rgba(231, 76, 60, 0.05);
}

.toolbar-btn:active {
  opacity: 0.7;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: var(--primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.empty-folder {
  width: 52rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary);
  border-radius: 4rpx 4rpx 8rpx 8rpx;
  position: relative;
}

.empty-folder::before {
  content: "";
  position: absolute;
  top: -12rpx;
  left: 0;
  width: 22rpx;
  height: 12rpx;
  border: 4rpx solid var(--primary);
  border-bottom: none;
  border-radius: 4rpx 4rpx 0 0;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 记录列表 */
.record-list {
  padding: 16rpx 32rpx;
}

/* 左滑删除容器 */
.swipe-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}

.swipe-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160px;
  background: #FF5252;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
}

.swipe-action:active {
  background: #e04545;
}

.record-card {
  background: var(--card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
  transition: transform 0.15s ease-out;
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.type-pill {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}

.pill-video {
  background: rgba(64, 158, 255, 0.1);
  color: #409EFF;
}

.pill-note {
  background: rgba(255, 153, 0, 0.1);
  color: #FF9900;
}

.record-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.record-desc {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.record-author {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
  display: block;
}

/* 视频 */
.record-media {
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-bottom: 12rpx;
}

.record-video {
  width: 100%;
  border-radius: var(--radius-sm);
}

/* 视频占位封面 */
.video-placeholder {
  width: 100%;
  height: 360rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  position: relative;
  overflow: hidden;
}

.video-cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.play-btn-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.play-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 18rpx 0 18rpx 30rpx;
  border-color: transparent transparent transparent #fff;
  margin-left: 6rpx;
}

.play-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  position: relative;
  z-index: 1;
}

.video-placeholder:active .play-btn-wrap {
  background: rgba(255, 255, 255, 0.35);
}

/* 图文缩略图 */
.thumb-scroll {
  display: flex;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.thumb-img {
  width: 160rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  margin-right: 10rpx;
  flex-shrink: 0;
  display: inline-block;
}

.thumb-count {
  font-size: 20rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 8rpx;
}

/* 底部操作 */
.record-bottom {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
}

.save-btn {
  padding: 8rpx 24rpx;
  font-size: 22rpx;
  color: var(--primary);
  background: var(--primary-light);
  border-radius: var(--radius-full);
  font-weight: 500;
}

.save-btn:active {
  background: rgba(108, 92, 231, 0.18);
}

.save-tip {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-left: 12rpx;
  align-self: center;
}

.save-btn-sub {
  color: var(--text-secondary);
  background: var(--bg);
}

.save-btn-sub:active {
  background: #E8E5F0;
}

.del-btn {
  padding: 8rpx 24rpx;
  font-size: 22rpx;
  color: #FF5252;
  background: rgba(255, 82, 82, 0.06);
  border-radius: var(--radius-full);
  font-weight: 500;
}

.del-btn:active {
  background: rgba(255, 82, 82, 0.15);
}

/* 加载动画 */
.loading-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.loading-dot-group {
  display: flex;
  gap: 12rpx;
}

.ldot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
  opacity: 0.3;
  animation: dotPulse 1.2s ease-in-out infinite;
}

.ldot:nth-child(2) { animation-delay: 0.2s; }
.ldot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.1); }
}

.end-line {
  text-align: center;
  padding: 24rpx 0 40rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}
